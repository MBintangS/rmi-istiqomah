# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/rmi?retryWrites=true&w=majority

# Auth (used in later sprints)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudinary (Sprint 28+)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
